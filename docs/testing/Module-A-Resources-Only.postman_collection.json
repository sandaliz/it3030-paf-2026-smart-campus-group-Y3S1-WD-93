                {
                  "key": "size",
                  "value": "10",
                  "description": "Number of items per page"
                },
                {
                  "key": "search",
                  "value": "lab",
                  "description": "Search term for name, location, description",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "ACTIVE",
                  "description": "Filter by status",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "LAB",
                  "description": "Filter by type",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "name",
                  "description": "Sort by field (name, capacity, etc.)",
                  "disabled": true
                },
                {
                  "key": "sortDir",
                  "value": "asc",
                  "description": "Sort direction (asc or desc)",
                  "disabled": true
                }
              ]
            },
            "description": "Get resources with pagination, sorting, and optional filtering"
          },
          "response": []
        },
        {
          "name": "Track Resource Share",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources/:resourceId/share",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", ":resourceId", "share"],
              "variable": [
                {
                  "key": "resourceId",
                  "value": "67f8a1b2e3c4d5e6f7a8b9c0",
                  "description": "Replace with actual resource ID"
                }
              ]
            },
            "description": "Increment the share count for a resource (for analytics)"
          },
          "response": []
        }
      ]
