{
  "info": {
    "name": "Smart Campus UniOps - Complete API",
    "description": "Complete Postman collection for all Smart Campus API endpoints (Modules A-E)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}"
      }
    ]
  },
  "item": [
    {
      "name": "Module E - Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@sliit.lk\",\"password\":\"pass123\",\"name\":\"Test User\",\"role\":\"STUDENT\"}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@sliit.lk\",\"password\":\"pass123\"}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["var jsonData=pm.response.json();if(jsonData.token)pm.collectionVariables.set(\"authToken\",jsonData.token);"]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "User Management (Admin)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Create User",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"lecturer@sliit.lk\",\"name\":\"Lecturer\",\"roles\":[\"LECTURER\"],\"enabled\":true}"
            },
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Update User Roles",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "body": {"mode": "raw", "raw": "{\"roles\":[\"ADMIN\",\"LECTURER\"]}"},
            "url": "{{baseUrl}}/api/admin/users/:userId/roles"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/users/:userId"
          }
        },
        {
          "name": "Get Technicians",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/technicians"
          }
        }
      ]
    },
    {
      "name": "Module A - Resources",
      "item": [
        {
          "name": "Get All Resources",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/resources?type=LECTURE_HALL&status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"],
              "query": [{"key": "type", "value": "LECTURE_HALL"}, {"key": "status", "value": "ACTIVE"}]
            }
          }
        },
        {
          "name": "Get Paginated Resources",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/paginated?page=0&size=10"
          }
        },
        {
          "name": "Get Resource by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/:resourceId"
          }
        },
        {
          "name": "Create Resource (Admin/Staff)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Main Hall\",\"type\":\"LECTURE_HALL\",\"capacity\":150,\"location\":\"Building A\",\"status\":\"ACTIVE\"}"
            },
            "url": "{{baseUrl}}/api/resources"
          }
        },
        {
          "name": "Get My Resources",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/my"
          }
        },
        {
          "name": "Bulk Create Resources (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {"mode": "raw", "raw": "[{\"name\":\"Lab 1\",\"type\":\"LAB\",\"capacity\":30},{\"name\":\"Lab 2\",\"type\":\"LAB\",\"capacity\":30}]"},
            "url": "{{baseUrl}}/api/resources/bulk"
          }
        },
        {
          "name": "Update Resource",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "body": {"mode": "raw", "raw": "{\"name\":\"Updated\",\"type\":\"LECTURE_HALL\",\"capacity\":200,\"location\":\"Building A\",\"status\":\"ACTIVE\"}"},
            "url": "{{baseUrl}}/api/resources/:resourceId"
          }
        },
        {
          "name": "Update Resource Status",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PATCH",
            "body": {"mode": "raw", "raw": "{\"status\":\"OUT_OF_SERVICE\"}"},
            "url": "{{baseUrl}}/api/resources/:resourceId/status"
          }
        },
        {
          "name": "Delete Resource",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/resources/:resourceId"
          }
        },
        {
          "name": "Get Resource Availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/:resourceId/availability?date=2026-04-20"
          }
        },
        {
          "name": "Check Resource Availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/:resourceId/availability/check?date=2026-04-20&startTime=09:00&endTime=10:00"
          }
        },
        {
          "name": "Get Resource Audit",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/:resourceId/audit"
          }
        }
      ]
    },
    {
      "name": "Module B - Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"resourceId\":\"res_id\",\"date\":\"2026-04-20\",\"startTime\":\"09:00\",\"endTime\":\"10:00\",\"purpose\":\"Lecture\",\"expectedAttendees\":50}"
            },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/my-bookings"
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/admin/all?status=PENDING"
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/:bookingId"
          }
        },
        {
          "name": "Update Booking Status (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PATCH",
            "body": {"mode": "raw", "raw": "{\"status\":\"APPROVED\",\"reason\":\"Approved\"}"},
            "url": "{{baseUrl}}/api/bookings/admin/:bookingId/status"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/bookings/:bookingId"
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/check-availability?resourceId=res_id&date=2026-04-20&startTime=09:00&endTime=10:00"
          }
        },
        {
          "name": "Get Available Slots",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/available-slots?resourceId=res_id&date=2026-04-20"
          }
        },
        {
          "name": "Get Booking Stats (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/admin/stats"
          }
        },
        {
          "name": "Export Bookings (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/admin/export?startDate=2026-04-01&endDate=2026-04-30"
          }
        }
      ]
    },
    {
      "name": "Module C - Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "title", "value": "Projector issue"},
                {"key": "description", "value": "Not working"},
                {"key": "category", "value": "EQUIPMENT"},
                {"key": "priority", "value": "HIGH"},
                {"key": "resourceId", "value": "res_id"},
                {"key": "location", "value": "Building A"}
              ]
            },
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/my-tickets?page=0&size=10"
          }
        },
        {
          "name": "Get All Tickets (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets?page=0&size=10"
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/:ticketId"
          }
        },
        {
          "name": "Update Ticket Status",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/:ticketId/status?status=IN_PROGRESS&reason=Assigned"
          }
        },
        {
          "name": "Assign Technician (Admin)",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/:ticketId/assign?technicianId=tech_id&technicianName=John"
          }
        },
        {
          "name": "Confirm Resolution",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/:ticketId/confirm?feedback=Fixed"
          }
        },
        {
          "name": "Search Tickets",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/search?keyword=projector"
          }
        }
      ]
    },
    {
      "name": "Ticket Comments",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {"mode": "raw", "raw": "{\"content\":\"Checking now\",\"isInternal\":false}"},
            "url": "{{baseUrl}}/api/tickets/:ticketId/comments"
          }
        },
        {
          "name": "Get Comments",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/:ticketId/comments"
          }
        },
        {
          "name": "Update Comment",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "body": {"mode": "raw", "raw": "{\"content\":\"Updated\"}"},
            "url": "{{baseUrl}}/api/tickets/:ticketId/comments/:commentId"
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/tickets/:ticketId/comments/:commentId"
          }
        }
      ]
    },
    {
      "name": "Ticket Attachments",
      "item": [
        {
          "name": "Upload Base64 Attachment",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {"mode": "raw", "raw": "{\"fileName\":\"img.jpg\",\"fileType\":\"image/jpeg\",\"base64Data\":\"...\"}"},
            "url": "{{baseUrl}}/api/attachments/upload-base64/:ticketId"
          }
        },
        {
          "name": "Get Ticket Attachments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/attachments/ticket/:ticketId"
          }
        },
        {
          "name": "Get Attachment Content",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/attachments/content/:attachmentId"
          }
        },
        {
          "name": "Delete Attachment",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/attachments/:attachmentId"
          }
        }
      ]
    },
    {
      "name": "Module D - Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications"
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications/unread-count"
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "url": "{{baseUrl}}/api/notifications/:id/read"
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "url": "{{baseUrl}}/api/notifications/read-all"
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "url": "{{baseUrl}}/api/notifications/:id"
          }
        }
      ]
    },
    {
      "name": "Notification Preferences",
      "item": [
        {
          "name": "Get Preferences",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/notification-preferences"
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "PUT",
            "body": {"mode": "raw", "raw": "{\"bookingNotifications\":true,\"ticketNotifications\":true,\"commentNotifications\":false}"},
            "url": "{{baseUrl}}/api/notification-preferences"
          }
        },
        {
          "name": "Check Preference",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/notification-preferences/check/BOOKING?channel=email"
          }
        }
      ]
    },
    {
      "name": "Admin Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard/stats"
          }
        },
        {
          "name": "Get Pending Bookings",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard/pending-bookings"
          }
        },
        {
          "name": "Get Open Tickets",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard/open-tickets"
          }
        },
        {
          "name": "Get All Resources",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard/resources"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/dashboard/users"
          }
        },
        {
          "name": "Approve Booking",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/dashboard/bookings/:id/approve"
          }
        },
        {
          "name": "Reject Booking",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "body": {"mode": "raw", "raw": "{\"reason\":\"Conflict\"}"},
            "url": "{{baseUrl}}/api/admin/dashboard/bookings/:id/reject"
          }
        }
      ]
    },
    {
      "name": "Google Calendar Integration",
      "item": [
        {
          "name": "Add Booking to Calendar",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "header": [{"key": "X-Google-Access-Token", "value": "{{googleAccessToken}}"}],
            "url": "{{baseUrl}}/api/calendar/add-booking/:bookingId"
          }
        },
        {
          "name": "Sync All Bookings",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "POST",
            "header": [{"key": "X-Google-Access-Token", "value": "{{googleAccessToken}}"}],
            "url": "{{baseUrl}}/api/calendar/sync-all"
          }
        },
        {
          "name": "Get Calendar Events",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "GET",
            "header": [{"key": "X-Google-Access-Token", "value": "{{googleAccessToken}}"}],
            "url": "{{baseUrl}}/api/calendar/events?startDate=2026-04-01T00:00:00&endDate=2026-04-30T23:59:59"
          }
        },
        {
          "name": "Remove from Calendar",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{authToken}}"}]},
            "method": "DELETE",
            "header": [{"key": "X-Google-Access-Token", "value": "{{googleAccessToken}}"}],
            "url": "{{baseUrl}}/api/calendar/remove-booking/:bookingId"
          }
        }
      ]
    }
  ]
}
