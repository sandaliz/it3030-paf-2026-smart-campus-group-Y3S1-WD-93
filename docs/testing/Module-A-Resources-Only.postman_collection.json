{
  "info": {
    "name": "Module A - Facilities & Assets Catalogue - after finishing up",
    "description": "Postman collection for Module A (Resources) endpoints only. Run Login request first to get JWT token for authenticated endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "Backend API base URL"
    },
    {
      "key": "authToken",
      "value": "",
      "description": "JWT token - Run Login request to populate this"
    }
  ],
  "item": [
    {
      "name": "Authentication (Required for Admin/Staff endpoints)",
      "item": [
        {
          "name": "Login - Get JWT Token",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sliit.lk\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login to get JWT token. Replace email/password with your admin/staff credentials. The token is automatically saved to authToken variable."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "  console.log('Token saved successfully');",
                  "} else {",
                  "  console.log('No token in response');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Create Admin/Staff Account",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sliit.lk\",\n  \"password\": \"admin123\",\n  \"name\": \"Admin User\",\n  \"role\": \"ADMIN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new admin or staff account. Use role: ADMIN or STAFF"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Public Endpoints (No Authentication Required)",
      "item": [
        {
          "name": "Get All Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources?type=LECTURE_HALL&status=ACTIVE&location=Main&minCapacity=50&search=hall",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources"],
              "query": [
                {
                  "key": "type",
                  "value": "LECTURE_HALL",
                  "description": "Filter by resource type (LECTURE_HALL, LAB, MEETING_ROOM, EQUIPMENT)",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "ACTIVE",
                  "description": "Filter by status (ACTIVE, OUT_OF_SERVICE, UNDER_MAINTENANCE)",
                  "disabled": true
                },
                {
                  "key": "location",
                  "value": "Main",
                  "description": "Filter by location (partial match, case-insensitive)",
                  "disabled": true
                },
                {
                  "key": "minCapacity",
                  "value": "50",
                  "description": "Filter by minimum capacity",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "hall",
                  "description": "Search across name, location, description (case-insensitive)",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieve all resources with optional filtering. All query parameters are optional."
          },
          "response": []
        },
        {
          "name": "Get Paginated Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources/paginated?page=0&size=10&search=lab&status=ACTIVE&type=LAB&sortBy=name&sortDir=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "resources", "paginated"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page number (0-indexed)"
